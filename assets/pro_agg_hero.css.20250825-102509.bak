/* assets/pro_agg_hero.css */
:root{
  --pro-agg-primary:#E67E22; /* Highlight Orange */
  --pro-agg-dark:#1C1C1C;
  --pro-agg-light:#FAFAFA;
}
.pro-agg-btn{display:inline-flex;align-items:center;justify-content:center;gap:.5rem;padding:.75rem 1.25rem;border-radius:8px;text-decoration:none;font-weight:600;transition:transform .12s ease, box-shadow .2s ease, background-color .2s ease, color .2s ease}
.pro-agg-btn:active{transform:translateY(1px)}
.pro-agg-btn--primary{background:var(--pro-agg-primary);color:#fff;box-shadow:0 4px 18px rgba(230,126,34,.35)}
.pro-agg-btn--primary:hover{box-shadow:0 6px 22px rgba(230,126,34,.46)}
.pro-agg-btn--secondary{background:#FFFFFF;color:var(--pro-agg-dark);border:1px solid rgba(0,0,0,.1)}
.pro-agg-btn--secondary:hover{border-color:rgba(0,0,0,.2)}
.pro-agg-btn--ghost{background:transparent;color:#fff;border:1px solid rgba(255,255,255,.6)}
.pro-agg-btn--ghost:hover{border-color:#fff}
.pro-agg-btn--sm{padding:.5rem .9rem;font-size:.9rem}
.pro-agg-btn--md{padding:.7rem 1.15rem;font-size:1rem}
.pro-agg-btn--lg{padding:.9rem 1.35rem;font-size:1.125rem}

/* Content typography (inherit Dawn scale nicely) */
.pro-agg-hero__eyebrow{letter-spacing:.08em;text-transform:uppercase;font-weight:600;opacity:.9}
.pro-agg-hero__title{font-size:clamp(1.75rem, 3vw + 1rem, 3rem);line-height:1.1}
.pro-agg-hero__body{font-size:clamp(1rem, .5vw + .8rem, 1.125rem);opacity:.95}

/* Safer focus styles for accessibility */
.pro-agg-hero button:focus-visible, .pro-agg-hero a:focus-visible{outline:2px solid #fff;outline-offset:2px}
