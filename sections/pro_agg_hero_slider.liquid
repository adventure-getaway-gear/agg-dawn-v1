{{ 'pro_agg_hero.css' | asset_url | stylesheet_tag }}
<script src="{{ 'pro_agg_hero.js' | asset_url }}" defer="defer"></script>

<section id="pro-agg-hero-{{ section.id }}" class="pro-agg-hero-slider" 
  data-autoplay="{{ section.settings.autoplay }}" 
  data-speed="{{ section.settings.autoplay_speed }}">
  <div class="pro-agg-slides">
    {% for block in section.blocks %}
      {% if block.type == 'slide' %}
        <div class="pro-agg-slide {% if forloop.first %}is-active{% endif %}" {{ block.shopify_attributes }}>
          <div class="pro-agg-media">
            {% if block.settings.image != blank %}
              {{ block.settings.image
                | image_url: width: 3840
                | image_tag: loading: 'lazy',
                              sizes: '(min-width: 990px) 100vw, 100vw',
                              widths: '375,750,1100,1500,1780,2000,3000,3840',
                              class: 'pro-agg-image' }}
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'pro-agg-image placeholder' }}
            {% endif %}
          </div>

          <div class="pro-agg-overlay">
            {%- comment -%}
              Independent 9-point positioning for heading, subheading, buttons
              via per-element wrappers with positioning classes.
            {%- endcomment -%}
            {% if block.settings.subheading != blank %}
              <div class="pro-agg-pos pro-agg-subheading {{ block.settings.subheading_position }}">
                <p class="pro-agg-subheading-text">{{ block.settings.subheading }}</p>
              </div>
            {% endif %}

            {% if block.settings.heading != blank %}
              <div class="pro-agg-pos pro-agg-heading {{ block.settings.heading_position }}">
                <h2 class="pro-agg-heading-text">{{ block.settings.heading }}</h2>
              </div>
            {% endif %}

            {% if block.settings.text != blank %}
              <div class="pro-agg-pos pro-agg-rich {{ block.settings.text_position }}">
                <div class="pro-agg-richtext">{{ block.settings.text }}</div>
              </div>
            {% endif %}

            {% assign has_btn1 = block.settings.button_label != blank and block.settings.button_link != blank %}
            {% assign has_btn2 = block.settings.show_second_button and block.settings.button2_label != blank and block.settings.button2_link != blank %}

            {% if has_btn1 or has_btn2 %}
              <div class="pro-agg-pos pro-agg-buttons {{ block.settings.buttons_position }}">
                <div class="pro-agg-buttons-row">
                  {% if has_btn1 %}
                    <a href="{{ block.settings.button_link }}" class="pro-agg-btn btn-1 {{ block.settings.button_style }}">
                      {{ block.settings.button_label }}
                    </a>
                  {% endif %}
                  {% if has_btn2 %}
                    <a href="{{ block.settings.button2_link }}" class="pro-agg-btn btn-2 {{ block.settings.button2_style }}">
                      {{ block.settings.button2_label }}
                    </a>
                  {% endif %}
                </div>
              </div>
            {% endif %}

            {% if block.settings.enable_sparkle %}
              <div class="pro-agg-sparkle" data-intensity="{{ block.settings.sparkle_intensity | default: 0.2 }}"></div>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  {%- comment -%} Basic controls; well enhance styling/logic next steps {%- endcomment -%}
  <div class="pro-agg-controls" aria-hidden="true">
    <button class="pro-agg-prev" type="button" aria-label="Previous slide"></button>
    <button class="pro-agg-next" type="button" aria-label="Next slide"></button>
  </div>
</section>

{% schema %}
{
  "name": "Pro AGG Hero Slider",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay slides",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 2000,
      "max": 9000,
      "step": 500,
      "unit": "ms",
      "label": "Autoplay speed (ms)",
      "default": 4000
    },
    {
      "type": "select",
      "id": "height_mode",
      "label": "Height mode",
      "default": "auto",
      "options": [
        { "value": "auto", "label": "Auto (match image)" },
        { "value": "fixed", "label": "Fixed height" }
      ]
    },
    {
      "type": "range",
      "id": "fixed_height",
      "label": "Fixed height (px)",
      "min": 360,
      "max": 900,
      "step": 20,
      "default": 600
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "limit": 8,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Slide image" },

        { "type": "text", "id": "heading", "label": "Heading", "default": "Adventure is calling" },
        { "type": "text", "id": "subheading", "label": "Subheading", "default": "Be ready for wherever the road takes you" },
        { "type": "richtext", "id": "text", "label": "Supporting text", "default": "<p>Explore our curated gear built for towing, travel, and outdoor life.</p>" },

        { "type": "select", "id": "heading_position", "label": "Heading position", "default": "pos-mid-center",
          "options": [
            { "value": "pos-top-left", "label": "Top left" },
            { "value": "pos-top-center", "label": "Top center" },
            { "value": "pos-top-right", "label": "Top right" },
            { "value": "pos-mid-left", "label": "Middle left" },
            { "value": "pos-mid-center", "label": "Middle center" },
            { "value": "pos-mid-right", "label": "Middle right" },
            { "value": "pos-bot-left", "label": "Bottom left" },
            { "value": "pos-bot-center", "label": "Bottom center" },
            { "value": "pos-bot-right", "label": "Bottom right" }
          ]
        },
        { "type": "select", "id": "subheading_position", "label": "Subheading position", "default": "pos-top-center",
          "options": [
            { "value": "pos-top-left", "label": "Top left" },
            { "value": "pos-top-center", "label": "Top center" },
            { "value": "pos-top-right", "label": "Top right" },
            { "value": "pos-mid-left", "label": "Middle left" },
            { "value": "pos-mid-center", "label": "Middle center" },
            { "value": "pos-mid-right", "label": "Middle right" },
            { "value": "pos-bot-left", "label": "Bottom left" },
            { "value": "pos-bot-center", "label": "Bottom center" },
            { "value": "pos-bot-right", "label": "Bottom right" }
          ]
        },
        { "type": "select", "id": "text_position", "label": "Supporting text position", "default": "pos-mid-center",
          "options": [
            { "value": "pos-top-left", "label": "Top left" },
            { "value": "pos-top-center", "label": "Top center" },
            { "value": "pos-top-right", "label": "Top right" },
            { "value": "pos-mid-left", "label": "Middle left" },
            { "value": "pos-mid-center", "label": "Middle center" },
            { "value": "pos-mid-right", "label": "Middle right" },
            { "value": "pos-bot-left", "label": "Bottom left" },
            { "value": "pos-bot-center", "label": "Bottom center" },
            { "value": "pos-bot-right", "label": "Bottom right" }
          ]
        },

        { "type": "text", "id": "button_label", "label": "Primary button label", "default": "Explore now" },
        { "type": "url", "id": "button_link", "label": "Primary button link" },
        { "type": "select", "id": "button_style", "label": "Primary button style", "default": "style-3d",
          "options": [
            { "value": "style-ghost", "label": "Ghost" },
            { "value": "style-solid", "label": "Solid" },
            { "value": "style-3d", "label": "3D" }
          ]
        },

        { "type": "checkbox", "id": "show_second_button", "label": "Show second button", "default": false },
        { "type": "text", "id": "button2_label", "label": "Second button label", "default": "Shop towing" },
        { "type": "url", "id": "button2_link", "label": "Second button link" },
        { "type": "select", "id": "button2_style", "label": "Second button style", "default": "style-ghost",
          "options": [
            { "value": "style-ghost", "label": "Ghost" },
            { "value": "style-solid", "label": "Solid" },
            { "value": "style-3d", "label": "3D" }
          ]
        },

        { "type": "select", "id": "buttons_position", "label": "Buttons position", "default": "pos-bot-left",
          "options": [
            { "value": "pos-top-left", "label": "Top left" },
            { "value": "pos-top-center", "label": "Top center" },
            { "value": "pos-top-right", "label": "Top right" },
            { "value": "pos-mid-left", "label": "Middle left" },
            { "value": "pos-mid-center", "label": "Middle center" },
            { "value": "pos-mid-right", "label": "Middle right" },
            { "value": "pos-bot-left", "label": "Bottom left" },
            { "value": "pos-bot-center", "label": "Bottom center" },
            { "value": "pos-bot-right", "label": "Bottom right" }
          ]
        },

        { "type": "checkbox", "id": "enable_sparkle", "label": "Enable sparkle overlay", "default": false },
        { "type": "range", "id": "sparkle_intensity", "label": "Sparkle intensity", "min": 0, "max": 1, "step": 0.05, "default": 0.2 }
      ]
    }
  ],
  "presets": [
    {
      "name": "Pro AGG Hero Slider",
      "category": "Image",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "heading": "Adventure is calling",
            "subheading": "Be ready for wherever the road takes you",
            "text": "<p>Explore our curated gear built for towing, travel, and outdoor life.</p>",
            "heading_position": "pos-mid-center",
            "subheading_position": "pos-top-center",
            "text_position": "pos-mid-center",
            "button_label": "Explore now",
            "button_style": "style-3d",
            "buttons_position": "pos-bot-left",
            "show_second_button": false
          }
        }
      ]
    }
  ]
}
{% endschema %}

{% stylesheet %}{% endstylesheet %}
