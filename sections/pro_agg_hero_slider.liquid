{% comment %}
  Pro AGG Hero Slider  Safe baseline
  - Minimal markup, valid schema (name <= 25 chars), includes presets
  - Autoplay speed max = 9000 (Shopify requires < 10000)
{% endcomment %}
{{ 'pro_agg_hero.css' | asset_url | stylesheet_tag }}
{{ 'pro_agg_hero.js' | asset_url | script_tag }}

<div class="pro-agg-hero"
     id="pro-agg-hero-{{ section.id }}"
     data-autoplay="{{ section.settings.autoplay }}"
     data-speed="{{ section.settings.autoplay_speed }}"
     data-show-dots="{{ section.settings.show_dots }}"
     data-show-arrows="{{ section.settings.show_arrows }}"
     data-position="{{ section.settings.content_position }}"
     data-overlay="{{ section.settings.overlay_opacity }}">
  <div class="pro-agg-hero__slides">
    {% for block in section.blocks %}
      <div class="pro-agg-hero__slide{% if forloop.first %} is-active{% endif %}" {{ block.shopify_attributes }}>
        {% if block.settings.image != blank %}
          <div class="pro-agg-hero__bg"
               style="background-image:url({{ block.settings.image | image_url: width: 2000 }});"></div>
        {% else %}
          <div class="pro-agg-hero__bg pro-agg-hero__bg--placeholder"></div>
        {% endif %}
        <div class="pro-agg-hero__overlay"></div>
        <div class="pro-agg-hero__content">
          {% if block.settings.heading != blank %}
            <h2 class="pro-agg-hero__heading">{{ block.settings.heading }}</h2>
          {% endif %}
          {% if block.settings.subheading != blank %}
            <p class="pro-agg-hero__subheading">{{ block.settings.subheading }}</p>
          {% endif %}
          {% if block.settings.button1_label != blank or block.settings.button2_label != blank %}
            <div class="pro-agg-hero__buttons">
              {% if block.settings.button1_label != blank %}
                <a class="btn-agg" href="{{ block.settings.button1_link | default: '#' }}">{{ block.settings.button1_label }}</a>
              {% endif %}
              {% if block.settings.button2_label != blank %}
                <a class="btn-agg btn-agg--secondary" href="{{ block.settings.button2_link | default: '#' }}">{{ block.settings.button2_label }}</a>
              {% endif %}
            </div>
          {% endif %}
        </div>
      </div>
    {% endfor %}

    {% if section.blocks.size == 0 %}
      <div class="pro-agg-hero__slide is-active">
        <div class="pro-agg-hero__bg pro-agg-hero__bg--placeholder"></div>
        <div class="pro-agg-hero__overlay"></div>
        <div class="pro-agg-hero__content">
          <h2 class="pro-agg-hero__heading">Pro AGG Hero Slider</h2>
          <p class="pro-agg-hero__subheading">Add slides in the theme editor</p>
          <div class="pro-agg-hero__buttons">
            <a class="btn-agg" href="#">Primary</a>
            <a class="btn-agg btn-agg--secondary" href="#">Secondary</a>
          </div>
        </div>
      </div>
    {% endif %}
  </div>

  {% if section.settings.show_arrows and section.blocks.size > 1 %}
    <button class="pro-agg-hero__arrow prev" aria-label="Previous slide"></button>
    <button class="pro-agg-hero__arrow next" aria-label="Next slide"></button>
  {% endif %}

  {% if section.settings.show_dots and section.blocks.size > 1 %}
    <div class="pro-agg-hero__dots" aria-label="Slide dots"></div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Pro AGG Hero Slider",
  "class": "section-pro-agg-hero",
  "settings": [
    { "type": "checkbox", "id": "autoplay", "label": "Autoplay", "default": true },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autoplay speed (ms)",
      "min": 1000,
      "max": 9000,
      "step": 500,
      "default": 4000
    },
    { "type": "checkbox", "id": "show_dots", "label": "Show dots", "default": true },
    { "type": "checkbox", "id": "show_arrows", "label": "Show arrows", "default": true },
    {
      "type": "select",
      "id": "content_position",
      "label": "Content position",
      "default": "middle-center",
      "options": [
        { "value": "top-left", "label": "Top left" },
        { "value": "top-center", "label": "Top center" },
        { "value": "top-right", "label": "Top right" },
        { "value": "middle-left", "label": "Middle left" },
        { "value": "middle-center", "label": "Middle center" },
        { "value": "middle-right", "label": "Middle right" },
        { "value": "bottom-left", "label": "Bottom left" },
        { "value": "bottom-center", "label": "Bottom center" },
        { "value": "bottom-right", "label": "Bottom right" }
      ]
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Image overlay opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Background image" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Your headline" },
        { "type": "text", "id": "subheading", "label": "Subheading", "default": "A short supporting line" },
        { "type": "text", "id": "button1_label", "label": "Primary button label", "default": "Shop now" },
        { "type": "url", "id": "button1_link", "label": "Primary button link" },
        { "type": "text", "id": "button2_label", "label": "Secondary button label" },
        { "type": "url", "id": "button2_link", "label": "Secondary button link" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Pro AGG Hero Slider",
      "category": "Image",
      "blocks": [
        { "type": "slide", "settings": { "heading": "Adventure is calling", "subheading": "Gear up for the road ahead", "button1_label": "Explore now" } }
      ]
    }
  ]
}
{% endschema %}
